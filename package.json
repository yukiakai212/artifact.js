{
  "name": "@yukiakai/artifact",
  "version": "1.0.2",
  "description": "Build deployment artifacts from project files.",
  "type": "module",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    "types": "./dist/public.d.ts",
    "import": "./dist/public.js",
    "require": "./dist/public.cjs"
  },
  "scripts": {
    "test": "npx vitest run --reporter verbose --coverage",
    "format": "prettier --write **/*.{js,ts,json}",
    "format:check": "prettier --check **/*.{js,ts,json}",
    "lint": "eslint src/**/*.ts",
    "typecheck:workspace": "tsc -p tsconfig.workspace.json",
    "generate:types": "npx type-export-builder generate -p src/_public.ts",
    "build": "npx tsup",
    "build:public": "npm run generate:types && npx tsup --config tsup.public.config.ts",
    "docs": "npx typedoc",
    "prepare:artifact": "tsx workspace/release/prepareArtifact.ts",
    "prepare": "is-ci || husky"
  },
  "files": [
    "dist/*",
    "CHANGELOG.md"
  ],
  "keywords": [
    "artifact",
    "build",
    "release",
    "deployment",
    "ci",
    "cd",
    "publish",
    "copy",
    "packaging"
  ],
  "author": "Yuki_akai",
  "homepage": "https://github.com/yukiakai212/artifact.js",
  "funding": "https://github.com/sponsors/yukiakai212",
  "engines": {
    "node": ">= 16"
  },
  "maintainers": [
    {
      "name": "Yuki_akai",
      "homepage": "https://github.com/yukiakai212"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiakai212/artifact.js.git"
  },
  "bugs": {
    "url": "https://github.com/yukiakai212/artifact.js/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv": "^17.0.1",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "type-export-builder": "^1.1.0",
    "typedoc": "^0.28.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.0.15"
  }
}
